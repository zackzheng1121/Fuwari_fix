---
import { Icon } from "astro-icon/components";
import { certificates, defaultCategory } from "../data/certificates";

interface Props {
	title?: string;
	description?: string;
	showHeader?: boolean;
	idPrefix?: string;
}

const {
	title = "證書/證明",
	description = "這裡是我的證書/證明清單，點擊可放大查看圖片。",
	showHeader = true,
	idPrefix = "certificate-section",
} = Astro.props;

const categories = Object.keys(certificates);
const showTabs = categories.length > 1;
---

<section id={idPrefix} class="card-base p-6 mb-4">
	{showHeader && (
		<div class="mb-6">
			<h1 class="text-3xl font-bold text-90 mb-2">{title}</h1>
			<p class="text-50 text-sm">{description}</p>
		</div>
	)}

	{showTabs && (
		<div class="flex flex-wrap gap-3 mb-8">
			{categories.map((category) => (
				<button
					type="button"
					data-category={category}
					class={`certificate-tab px-6 py-2.5 rounded-lg font-medium transition-all ${
						category === defaultCategory
							? "btn-regular-dark text-white"
							: "btn-regular text-75"
					}`}
				>
					{category}
				</button>
			))}
		</div>
	)}

	<div data-certificates-container class="grid grid-cols-1 md:grid-cols-2 gap-6">
		{certificates[defaultCategory]?.map((cert, index) => (
			<div
				data-image={cert.image}
				data-name={cert.name}
				role="button"
				tabindex="0"
				class="certificate-card card-base card-shadow group relative p-6 transition-all duration-300 onload-animation hover:shadow-xl text-left"
				style={`animation-delay: ${index * 100}ms`}
			>
				<div class="certificate-gallery flex justify-center items-center h-64 mb-6 bg-[var(--btn-regular-bg)] rounded-xl overflow-hidden">
					<img
						src={cert.image}
						alt={cert.name}
						class="w-auto h-full object-contain group-hover:scale-105 transition-transform duration-300"
					/>
				</div>

				<div class="text-center">
					<h3 class="text-xl font-bold text-90 mb-2 group-hover:text-[var(--primary)] transition-colors">
						{cert.name}
					</h3>
					<div class="flex items-center justify-center gap-2 mb-2">
						<Icon name="material-symbols:verified-outline" class="text-lg text-75" />
						<p class="text-75 font-medium">{cert.issuer}</p>
					</div>
					<div class="flex items-center justify-center gap-2 mb-3">
						<Icon name="material-symbols:calendar-month-outline" class="text-lg text-75" />
						<p class="text-75 font-medium">{cert.date}</p>
					</div>
				</div>
			</div>
		))}
	</div>

	{!certificates[defaultCategory]?.length && (
		<div class="text-center text-50 text-sm py-10">目前還沒有證書資料</div>
	)}

</section>

<script define:vars={{ certificates, defaultCategory, idPrefix, showTabs }}>
	const root = document.getElementById(idPrefix);
	if (root) {
		const tabs = root.querySelectorAll(".certificate-tab");
		const container = root.querySelector("[data-certificates-container]");

		if (showTabs && tabs.length && container) {
			tabs.forEach((tab) => {
				tab.addEventListener("click", () => {
					const category = tab.dataset.category;
					if (!category) return;

					tabs.forEach((t) => {
						t.classList.remove("btn-regular-dark", "text-white");
						t.classList.add("btn-regular", "text-75");
					});
					tab.classList.add("btn-regular-dark", "text-white");
					tab.classList.remove("btn-regular", "text-75");

					const list = certificates[category] || [];
					if (!list.length) {
						container.innerHTML = '<div class="text-center text-50 text-sm py-10">目前還沒有證書資料</div>';
						return;
					}

					container.innerHTML = list
						.map(
							(cert, index) => `
								<div
									data-image="${cert.image}"
									data-name="${cert.name}"
									role="button"
									tabindex="0"
									class="certificate-card card-base card-shadow group relative p-6 transition-all duration-300 hover:shadow-xl text-left"
									style="animation-delay: ${index * 100}ms; animation: fadeInUp 0.3s ease-out forwards;"
								>
									<div class="certificate-gallery flex justify-center items-center h-64 mb-6 bg-[var(--btn-regular-bg)] rounded-xl overflow-hidden">
										<img
											src="${cert.image}"
											alt="${cert.name}"
											class="w-auto h-full object-contain group-hover:scale-105 transition-transform duration-300"
										/>
									</div>
									<div class="text-center">
										<h3 class="text-xl font-bold text-90 mb-2 group-hover:text-[var(--primary)] transition-colors">
											${cert.name}
										</h3>
										<div class="flex items-center justify-center gap-2 mb-2">
											<svg class="w-5 h-5 text-75" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
											</svg>
											<p class="text-75 font-medium">${cert.issuer}</p>
										</div>
										<div class="flex items-center justify-center gap-2 mb-3">
											<svg class="w-5 h-5 text-75" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10m4 10H4a2 2 0 01-2-2V7a2 2 0 012-2h16a2 2 0 012 2v10a2 2 0 01-2 2z" />
											</svg>
											<p class="text-75 font-medium">${cert.date}</p>
										</div>
										<p class="text-sm text-50 leading-relaxed mb-3">${cert.description}</p>
										<div class="flex items-center justify-center gap-1 text-[var(--primary)] opacity-0 group-hover:opacity-100 transition-opacity">
											<span class="text-sm font-medium">點擊圖片放大</span>
											<svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h8m-4-4v8" />
											</svg>
										</div>
									</div>
								</div>
							`,
						)
						.join("");

					window.dispatchEvent(new Event("pswp:refresh"));
				});
			});
		}

		const triggerZoom = (card) => {
			if (!(card instanceof HTMLElement)) return;
			const img = card.querySelector("img");
			if (img instanceof HTMLImageElement) img.click();
		};

		root.addEventListener("click", (event) => {
			const target = event.target;
			if (!(target instanceof HTMLElement)) return;
			if (target instanceof HTMLImageElement) return;
			const card = target.closest(".certificate-card");
			if (card) triggerZoom(card);
		});

		root.addEventListener("keydown", (event) => {
			const target = event.target;
			if (!(target instanceof HTMLElement)) return;
			if (event.key !== "Enter" && event.key !== " ") return;
			const card = target.closest(".certificate-card");
			if (!card) return;
			event.preventDefault();
			triggerZoom(card);
		});
	}
</script>

<style>
	:global(.certificate-tab) {
		cursor: pointer;
	}

	:global(.certificate-card) {
		border: 1px solid var(--line-divider);
	}

	:global(.certificate-card:hover) {
		border-color: var(--btn-regular-bg-hover);
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>
